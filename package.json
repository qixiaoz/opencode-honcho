{
  "name": "@honcho-ai/opencode-honcho",
  "version": "0.1.3",
  "type": "module",
  "description": "Honcho memory integration for OpenCode",
  "license": "MIT",
  "packageManager": "bun@1.3.9",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "import": "./dist/server.js"
    },
    "./tui": {
      "import": "./dist/tui.js"
    },
    "./capabilities": {
      "types": "./dist/capabilities.d.ts",
      "import": "./dist/capabilities.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "bun --eval \"const { rm } = await import('node:fs/promises'); await rm('dist', { recursive: true, force: true })\" && bun build ./src/index.ts ./src/server.ts ./src/tui.ts ./src/capabilities.ts --outdir ./dist --target bun --external @opencode-ai/plugin && tsc --emitDeclarationOnly",
    "check": "tsc --noEmit",
    "test": "bun run build && bun test ./tests",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@honcho-ai/sdk": "^2.1.1",
    "@opencode-ai/plugin": "^1.3.13"
  },
  "devDependencies": {
    "@types/bun": "^1.2.8",
    "@types/node": "^22.13.9",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3"
  }
}
